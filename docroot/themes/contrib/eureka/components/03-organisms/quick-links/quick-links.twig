{#
/**
 * Available variables:
 * - quick_links_base_class: base classname of the wrapper.
 * - quick_links_modifiers: array of modifiers to add to the base classname of the wrapper.
 * - quick_links_blockname: blockname prepended to the base classname of the wrapper(s) and each component.
 * - quick_links_extra_classes: array of extra classes to add to the base classes.
 *
 * - quick_links_heading: heading text of the quick links component.
 * - quick_links_heading_level: heading level of the quick links component.
 * - quick_links_summary: summary text of the quick links component.
 *
 * - quick_links_items: rendered HTML of the quick links items.
 */
#}

{% set quick_links_base_class = 'quick-links' %}
{% set quick_links_modifiers =  quick_links_modifiers|default([]) %}
{% set quick_links_extra_classes =  quick_links_extra_classes|default([])|merge(['component']) %}

<div {{ bem(quick_links_base_class, quick_links_modifiers, quick_links_blockname, quick_links_extra_classes) }}>
  <div class="container">
    {{ include('eureka:component-title', {
      component_title_centered: true,
      component_title_heading: quick_links_heading,
      component_title_heading_level: quick_links_heading_level,
      component_title_summary: quick_links_summary,
    }, with_context = false) }}
    <div {{ bem('items', [], quick_links_base_class) }}>
      {% block quick_links_items_block %}
        {{ quick_links_items }}
      {% endblock %}
    </div>
  </div>
</div>
