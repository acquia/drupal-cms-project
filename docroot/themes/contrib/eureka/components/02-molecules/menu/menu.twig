{#
/**
 * @file
 * Theme override to display a menu.
 *
 * Available variables:
 * - menu_name: The machine name of the menu.
 * - items: A nested list of menu items. Each menu item contains:
 *   - attributes: HTML attributes for the menu item.
 *   - below: The menu item child items.
 *   - title: The menu link title.
 *   - url: The menu link url, instance of \Drupal\Core\Url
 *   - localized_options: Menu link localized options.
 *   - is_expanded: TRUE if the link has visible children within the current
 *     menu tree.
 *   - is_collapsed: TRUE if the link has children within the current menu tree
 *     that are not currently visible.
 *   - in_active_trail: TRUE if the link is in the active trail.
 *
 * Available blocks:
 * - list_content_block
 */
#}

{#
  We call a macro which calls itself to render the full tree.
  @see http://twig.sensiolabs.org/doc/tags/macro.html
#}

{% macro menu_links(menu_items, attributes, menu_level, menu_class, menu_modifiers, menu_blockname, menu_extra_classes, item_base_class, directory) %}
  {% import _self as menus %}
  {% if menu_items %}
    {# Set classes #}
    {% set menu_class = menu_class|default('menu') %}
    {% set menu_modifiers = menu_modifiers|default([]) %}
    {% set menu_extra_classes = menu_extra_classes|default([])|merge(['list--unstyled']) %}
    {# Add modifier for submenus #}
    {% if menu_level > 0 %}
      {% set menu_modifiers = menu_modifiers|merge(['sub', 'sub-' ~ menu_level]) %}
    {% endif %}
    {# Menu list #}
    {% embed "eureka:list" with {
      list_base_class: menu_class,
      list_modifiers: menu_modifiers,
      list_blockname: menu_blockname,
      list_extra_classes: menu_extra_classes,
    } %}
      {% block list_content_block %}
        {% for item in menu_items %}
          {{ include("eureka:menu-item") }}
        {% endfor %}
      {% endblock %}
    {% endembed %}
  {% endif %}
{% endmacro %}

{% import _self as menus %}
{{ menus.menu_links(menu_items, attributes, 0, menu_class, menu_modifiers, menu_blockname, menu_extra_classes, item_base_class, directory) }}
