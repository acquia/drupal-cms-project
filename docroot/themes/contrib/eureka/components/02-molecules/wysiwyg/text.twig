{#
/**
 * Available variables:
 * - text_base_class: base classname of the wrapper.
 * - text_modifiers: array of modifiers to add to the base classname of the wrapper.
 * - text_blockname: blockname prepended to the base classname of the wrapper(s) and each component.
 * - text_extra_classes: array of extra classes to add to the base classes.
 *
 * - text_content: text content - fully formatted.
 */
#}

{% set text_base_class = 'text' %}
{% set text_extra_classes =  text_extra_classes|default([])|merge(['component']) %}

<div {{ bem(text_base_class, text_modifiers, text_blockname, text_extra_classes) }}>
  <div {{ bem('inner', [], text_base_class, ['container', 'container--small']) }}>
    {{ text_content }}
  </div>
</div>
