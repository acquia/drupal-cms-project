<div class="space-logo-section">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-y-8 lg:gap-x-6 lg:gap-y-0 xl:gap-14 items-start">
      <div class="space-logo-section__content">
        {% if pre_heading %}
          <p class="space-logo-section__pre-heading">{{ pre_heading }}</p>
        {% endif %}
        
        {% if heading %}
          {% include 'pulse_theme:space-heading' with { content: heading, tag_name: tag_name, modifier: 'h1' } only %}
        {% endif %}

        {% if description %}
          <div class="space-logo-section__body">
            {{ description }}
          </div>
        {% endif %}
      </div>

      <div class="space-logo-section col-span-2">
        {% block content %}
          {{ content }}
        {% endblock %}
      </div>
    </div>
  </div>
</div>
