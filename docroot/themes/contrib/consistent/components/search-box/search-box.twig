<form action="/search" method="get" role="search">
  <label for="search-input" class="sr-only">{{ 'Search'|t }}</label>
  <div class="flex">
    <input
      type="search"
      id="search-input"
      name="keys"
      placeholder="{{ search_placeholder|default('I\'m looking for...'|t) }}"
      class="flex-1 h-11 px-4 text-base border border-r-0 text-foreground bg-background border-border rounded-l-[var(--radius-sm)] focus:outline-none focus:bg-focus focus:text-focus-text focus:shadow-[0_2px_0_0_var(--color-foreground)]"
    />
    <button type="submit" class="h-11 w-11 flex items-center justify-center shrink-0 bg-secondary text-foreground rounded-r-[var(--radius-sm)] transition duration-200 hover:brightness-90 focus:outline-none focus:bg-focus focus:text-focus-text focus:shadow-[0_2px_0_0_var(--color-foreground)]" aria-label="{{ 'Search'|t }}">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </button>
  </div>
</form>
