<div class="stwl-container">
  <div class="grid grid-cols-1 grid-rows-[auto_auto] md:grid-rows-1">

    {% if media is not empty and media.src is not empty %}
      {% include 'canvas:image' ignore missing with {
        src: media.src,
        alt: media.alt,
        class: 'w-full h-auto block md:[grid-area:1/1] md:row-span-full',
        width: media.width,
        height: media.height
      } only %}
    {% endif %}

    <div class="rounded-[var(--radius-sm)] bg-primary text-white p-6 md:p-8 md:[grid-area:1/1] md:self-end md:justify-self-start md:mb-8 md:ml-8 md:max-w-sm">
      {% if heading_text is not empty %}
        <p class="text-base mb-1 opacity-90">{{ heading_text }}</p>
      {% endif %}
      {% if subtitle is not empty %}
        <h1 class="text-2xl md:text-3xl font-bold mb-4">{{ subtitle }}</h1>
      {% endif %}
      {% if show_search|default(false) %}
        <form action="/search" method="get" class="flex" role="search">
          <label for="hero-search" class="sr-only">Search</label>
          <input type="search" id="hero-search" name="keywords" placeholder="I'm looking for..." class="flex-1 h-10 px-3 text-foreground bg-white text-base border-0 rounded-l-[var(--radius-sm)]"/>
          <button type="submit" class="h-10 w-10 flex items-center justify-center bg-yellow text-foreground rounded-r-[var(--radius-sm)] cursor-pointer hover:brightness-90 transition duration-200 focus:outline-none focus:bg-focus focus:text-focus-text focus:shadow-[0_2px_0_0_var(--color-foreground)]" aria-label="Search">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </button>
        </form>
      {% elseif cta_label is not empty and cta_url is not empty %}
        <a href="{{ cta_url }}" class="inline-flex items-center gap-2 px-5 py-2 font-bold no-underline text-base transition duration-200 bg-yellow text-foreground rounded-[var(--radius)] hover:brightness-90 focus:outline-none focus:bg-focus focus:text-focus-text focus:shadow-[0_2px_0_0_var(--color-foreground)]">
          {{ cta_label }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      {% endif %}
    </div>

  </div>
</div>
