{% set heading_level = heading_level|default(2) %}
{% set has_url = heading_url is not empty and heading_url != 'No URL' %}

{% set heading_content %}
  {% if has_url %}
    <a href="{{ heading_url }}">{{ heading_text }}</a>
  {% else %}
    {{ heading_text }}
  {% endif %}
{% endset %}

{% if heading_level == 1 %}
  <h1 class="font-bold text-3xl md:text-4xl">{{ heading_content }}</h1>
{% elseif heading_level == 2 %}
  <h2 class="font-bold text-2xl md:text-3xl">{{ heading_content }}</h2>
{% elseif heading_level == 3 %}
  <h3 class="font-bold text-xl md:text-2xl">{{ heading_content }}</h3>
{% elseif heading_level == 4 %}
  <h4 class="font-bold text-lg md:text-xl">{{ heading_content }}</h4>
{% elseif heading_level == 5 %}
  <h5 class="font-bold text-base md:text-lg">{{ heading_content }}</h5>
{% elseif heading_level == 6 %}
  <h6 class="font-bold text-base">{{ heading_content }}</h6>
{% else %}
  <h2 class="font-bold text-2xl md:text-3xl">{{ heading_content }}</h2>
{% endif %}
