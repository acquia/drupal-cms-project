{% set has_url = url is not empty ? 'yes' : 'no' %}

{% set tile =
  html_cva(
    base: ['relative h-full p-6 hover:scale-103 hover:shadow-sm md:p-8'],
    variants: {
      hasUrl: {
        yes: 'group cursor-pointer hover:scale-103',
        no: ''
      },
      backgroundColor: {
        primary: 'bg-primary text-primary-foreground shadow-lg transition duration-300',
        secondary: 'bg-secondary text-secondary-foreground shadow-lg transition duration-300',
        accent: 'bg-accent text-accent-foreground shadow-lg transition duration-300',
        muted: 'bg-muted text-muted-foreground shadow-lg transition duration-300',
        bright: 'bg-bright text-bright-foreground shadow-lg transition duration-300 hover:bg-bright/80',
        light: 'bg-light text-light-foreground shadow-lg transition duration-300 hover:bg-light/80',
        noColor: 'bg-none text-foreground transition duration-300'
      },
      tileSize: {
        square: 'lg:aspect-square',
        '4:3': 'lg:aspect-4/3',
        '16:9': 'lg:aspect-16/9',
        noSize: 'aspect-none'
      },
      borderRadius: {
        small: 'rounded-sm',
        medium: 'rounded-xl md:rounded-2xl',
        large: 'rounded-[24px] md:rounded-[32px]',
        noRadius: 'rounded-none'
      }
    }
  )
%}

{% set tile_classes =
  tile.apply({
    hasUrl: has_url,
    backgroundColor: background_color|default('noColor'),
    tileSize: tile_size|default('noSize'),
    borderRadius: border_radius|default('noRadius')
  })
%}

{% set icon_container =
  html_cva(
    base: ['flex', 'w-full'],
    variants: {
      iconAlign: {
        left: 'justify-start',
        center: 'justify-center',
        right: 'justify-end'
      }
    }
  )
%}

{% set icon_container_classes =
  icon_container.apply({
    iconAlign: icon_align|default('center')
  })
%}

{% set icon_size_map = {
  small: 'small',
  medium: 'medium',
  large: 'large',
  'extra-large': 'extra-large'
} %}

{% set text_container =
  html_cva(
    base: ['w-full', 'pt-2'],
    variants: {
      textAlign: {
        left: 'text-start',
        center: 'text-center',
        right: 'text-end'
      }
    }
  )
%}

{% set text_container_classes =
  text_container.apply({
    textAlign: text_align|default('center')
  })
%}

<div class="{{ tile_classes }}">
  <div class="flex h-full flex-col justify-center">
    <div class="{{ icon_container_classes }}">
      {% if icon %}
        {{
          include(
            '@diagnosis/components/icon/icon.twig',
            {
              icon: icon,
              icon_size: icon_size_map[icon_size]|default('medium')
            },
            with_context: false
          )
        }}
      {% endif %}
    </div>

    <div class="{{ text_container_classes }}">
      {% if text is not empty or description is not empty or button_text is not empty %}
        {# If there's a URL but no button text, make the whole card clickable #}
        {% if url is not empty and button_text is empty %}
          <a href="{{ url }}" class="flex w-full flex-col before:absolute before:inset-0 before:content-['']">
            {% if text is not empty %}
              <h3>{{ text }}</h3>
            {% endif %}
            {% if description is not empty %}
              <span class="mt-3">{{ description }}</span>
            {% endif %}
          </a>
        {% else %}
          <div class="flex w-full flex-col">
            {% if text is not empty %}
              <h3>{{ text }}</h3>
            {% endif %}
            {% if description is not empty %}
              <span class="mt-3">{{ description }}</span>
            {% endif %}

            {# Button #}
            {% if button_text is not empty %}
              <div class="relative z-10 mt-4">
                {{
                  include(
                    '@diagnosis/components/button/button.twig',
                    {
                      label: button_text,
                      href: url|default(''),
                      variant: button_variant|default('primary'),
                      size: button_size|default('medium'),
                      icon: button_icon|default(null),
                      icon_first: button_icon_first|default(false),
                      mobile_width: button_mobile_width|default(false)
                    },
                    with_context: false
                  )
                }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endif %}
    </div>
  </div>
</div>
