{#
  Story Share & Tags — "Share this story" heading, social share buttons, and category tags.
  Figma: desktop node 1:7432 (horizontal), mobile node 1:7218 (stacked).
#}
{% set heading = share_heading|default('Share this story') %}
{% set tag_items = [tag_1, tag_2, tag_3, tag_4] %}
{% set has_any_tag = (tag_1|default('')|trim != '') or (tag_2|default('')|trim != '') or (tag_3|default('')|trim != '') or (tag_4|default('')|trim != '') %}

<div
  class="story-share-tags"
  {% if share_url is not empty %}data-share-url="{{ share_url }}"{% endif %}
  {% if link_copy_url is not empty %}data-link-copy-url="{{ link_copy_url }}"{% endif %}
  {% if link_linkedin_url is not empty %}data-link-linkedin-url="{{ link_linkedin_url }}"{% endif %}
  {% if link_x_url is not empty %}data-link-x-url="{{ link_x_url }}"{% endif %}
  {% if link_facebook_url is not empty %}data-link-facebook-url="{{ link_facebook_url }}"{% endif %}
>
  <div class="story-share-tags__share" role="group" aria-label="Share">
    {% if heading is not empty %}
      <p class="story-share-tags__heading">{{ heading }}</p>
    {% endif %}
    <div class="story-share-tags__buttons">
      <a href="#" class="story-share-tags__btn story-share-tags__btn--link" data-action="copy-link" aria-label="Copy link" title="Copy link">
        <svg width="24" height="24" viewbox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="{{ link_linkedin_url is not empty ? link_linkedin_url : '#' }}" class="story-share-tags__btn story-share-tags__btn--linkedin" data-action="share-linkedin" aria-label="Share on LinkedIn" title="Share on LinkedIn" target="_blank" rel="noopener noreferrer">
        <svg width="24" height="24" viewbox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href="{{ link_x_url is not empty ? link_x_url : '#' }}" class="story-share-tags__btn story-share-tags__btn--x" data-action="share-x" aria-label="Share on X" title="Share on X" target="_blank" rel="noopener noreferrer">
        <svg width="24" height="24" viewbox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="{{ link_facebook_url is not empty ? link_facebook_url : '#' }}" class="story-share-tags__btn story-share-tags__btn--facebook" data-action="share-facebook" aria-label="Share on Facebook" title="Share on Facebook" target="_blank" rel="noopener noreferrer">
        <svg width="24" height="24" viewbox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
    </div>
  </div>

  {% if has_any_tag %}
    <div class="story-share-tags__tags">
      {% for tag in tag_items %}
        {% if tag is defined and tag is not null and tag|trim != '' %}
          <span class="story-share-tags__tag">{{ tag }}</span>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>
