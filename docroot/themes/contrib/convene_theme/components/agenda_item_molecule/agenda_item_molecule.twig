{% set classes = [
  'agenda-item',
  admin_theme ? 'agenda-item--admin-theme' : 'agenda-item--themed',
] %}

<div{{attributes.addClass(classes)}}>
  <div class="agenda-item__marker-container">
    <div class="agenda-item__dot"></div>
    <div class="agenda-item__line"></div>
  </div>
  <div class="agenda-item__content">
    {% if title %}
      <div class="agenda-item__title">{{ title }}</div>
    {% endif %}
    {% if subtitle %}
      <div class="agenda-item__subtitle">{{ subtitle }}</div>
    {% endif %}
    {% if description %}
      <div class="agenda-item__description-text">{{ description }}</div>
    {% endif %}
    
    {% if actions %}
      <div class="agenda-item__buttons">
        {{ actions }}
      </div>
    {% endif %}
  </div>
</div>
