<section class="featured-speakers {{ admin_theme ? 'featured-speakers--admin-theme' : 'featured-speakers--themed' }} {{ list_view ? 'featured-speakers--list' : '' }}">
	<div class="featured-speakers__header">
		<div class="featured-speakers__text">
			{% if eyebrow_slot %}
				<div class="featured-speakers__eyebrow">{{ eyebrow_slot }}</div>
			{% endif %}
			{% if title_slot %}
				<div class="featured-speakers__title">{{ title_slot }}</div>
			{% endif %}
			{% if description_slot %}
				<div class="featured-speakers__description">{{ description_slot }}</div>
			{% endif %}
		</div>
	</div>

	<div class="featured-speakers__slider-container">
		<div class="featured-speakers__slider" role="region" aria-label="Speakers Slider">
			{{ speakers }}
		</div>
	</div>

	{% if not list_view %}
		<div class="featured-speakers__controls">
			<div
				class="featured-speakers__dots">{# Dots will be generated by JS #}
			</div>
			<div class="featured-speakers__arrows">
				<button class="featured-speakers__nav featured-speakers__nav--prev" aria-label="Previous slide" disabled>
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
				</button>
				<button class="featured-speakers__nav featured-speakers__nav--next" aria-label="Next slide">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
				</button>
			</div>
		</div>
	{% endif %}

	<div class="featured-speakers__bottom">
		<div class="featured-speakers__more">
			{% if more_title %}
				<h3 class="featured-speakers__more-title">{{ more_title }}</h3>
			{% endif %}
			{% if more_description %}
				<p class="featured-speakers__more-desc">{{ more_description }}</p>
			{% endif %}
			{% if more_button_slot %}
				<div class="featured-speakers__action">{{ more_button_slot }}</div>
			{% endif %}
		</div>
	</div>
</section>
