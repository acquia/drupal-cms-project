<?php

/**
 * @file
 * Acquia Trials Countdown module.
 */

/**
 * Fetches the trial end timestamp from the Acquia API.
 *
 * @return int
 *   The trial end Unix timestamp.
 */
function acquia_trials_countdown_fetch_trial_end(): int {
  $subscription_id = getenv('SUBSCRIPTION_ID') ?: '';
  return \Drupal::service('acquia_trials_countdown.trial_end_client')
    ->fetchTrialEnd($subscription_id);
}

/**
 * Implements hook_cron().
 */
function acquia_trials_countdown_cron() {
  $trial_end = acquia_trials_countdown_fetch_trial_end();
  \Drupal::state()->set('acquia_trials_countdown.trial_end', $trial_end);
}

/**
 * Implements hook_page_attachments().
 */
function acquia_trials_countdown_page_attachments(array &$attachments) {
  $trial_end = \Drupal::state()->get('acquia_trials_countdown.trial_end');
  if (empty($trial_end)) {
    return;
  }

  $attachments['#attached']['library'][] = 'acquia_trials_countdown/countdown-banner';
  $attachments['#attached']['drupalSettings']['trialsCountdown'] = [
    'endTimestamp' => $trial_end,
  ];
}
