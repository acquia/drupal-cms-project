<?php

/**
 * @file
 * Hook implementations for ai_agents_tools_test.
 */

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\Core\Render\BubbleableMetadata;
use Drupal\ai_agents_tools_test\Hook\AiAgentsToolsTestHooks;

/**
 * Implements hook_token_info().
 */
#[LegacyHook]
function ai_agents_tools_test_token_info(): array {
  return \Drupal::service(AiAgentsToolsTestHooks::class)->tokenInfo();
}

/**
 * Implements hook_tokens().
 */
#[LegacyHook]
function ai_agents_tools_test_tokens(string $type, array $tokens, array $data = [], array $options = [], ?BubbleableMetadata $bubbleable_metadata = NULL): array {
  return \Drupal::service(AiAgentsToolsTestHooks::class)->tokens($type, $tokens, $data, $options, $bubbleable_metadata);
}
