{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Canvas global region spec",
  "description": "Authored Canvas global region format. Workbench normalizes this into an @json-render/react-compatible spec by synthesizing the canvas:component-tree root wrapper.",
  "type": "object",
  "required": ["elements"],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1,
      "description": "Optional JSON Schema reference for editor tooling."
    },
    "status": {
      "type": "boolean",
      "description": "Whether the region is enabled."
    },
    "elements": {
      "type": "object",
      "description": "Authored region elements. Workbench preserves key insertion order when synthesizing canvas:component-tree children.",
      "propertyNames": {
        "not": {
          "const": "canvas:component-tree"
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/element"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "element": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "props": {},
        "slots": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "_provenance": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}
