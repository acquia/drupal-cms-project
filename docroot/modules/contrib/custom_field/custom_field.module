/**
 * Prepares variables for custom-field template.
 *
 * The preprocess function is now registered as an 'initial preprocess'
 * callback in hook_theme(). This procedural wrapper exists only for
 * backwards compatibility with Drupal core < 11.2.
 */
function template_preprocess_custom_field(array &$variables): void {
  \Drupal::service(ThemeHooks::class)->preprocessCustomField($variables);
}

