/**
 * Implements hook_module_implements_alter().
 */
// @phpstan-ignore-next-line
#[LegacyModuleImplementsAlter]
// phpcs:ignore Squiz.WhiteSpace.FunctionSpacing.Before
function custom_field_module_implements_alter(array &$implementations, string $hook): void {
  if ($hook === 'node_update') {
    // Make sure we run after taxonomy so the index doesn't get deleted.
    if (isset($implementations['taxonomy'])) {
      $group = $implementations['custom_field'];
      unset($implementations['custom_field']);
      // Put our module right after.
      $implementations['custom_field'] = $group;
    }
  }
}
