<?php

/**
 * @file
 * Custom field media module file.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\custom_field_media\Hook\ConfigSchemaHooks;

/**
 * Implements hook_config_schema_info_alter().
 */
// @phpstan-ignore-next-line
#[LegacyHook]
// phpcs:ignore Squiz.WhiteSpace.FunctionSpacing.Before
function custom_field_media_config_schema_info_alter(array &$definitions): void {
  \Drupal::service(ConfigSchemaHooks::class)->configSchemaInfoAlter($definitions);
}
