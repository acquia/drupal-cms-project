        "drupal/provus_edu_theme": "^1.0.3",
        "drupal/provus_mega_menu": "^1.0.3",
        "drupal/pulse_theme": "^1.0.0",
        "drupal/recipe_installer_kit": "^1.0.4",
        "drupal/redirect": "^1.13.0",
        "drupal/robotstxt": "^1.6.0",
        "drupal/sam": "^1.3.2",
        "drupal/scheduler": "^2.2.2",
        "drupal/scheduler_content_moderation_integration": "^3.0.5",
